{
  "name": "research-assistant",
  "title": "Research Assistant \u2014 Multi-Source Search with Knowledge Graph",
  "description": "A research gateway that composes 5 microservices into powerful virtual tools. Demonstrates output transforms (normalize heterogeneous APIs), scatter-gather (parallel multi-source search), pipelines (search \u2192 fetch \u2192 merge), and cross-service data flow. Base MCP tools and virtual tools are on equal footing in the registry.",
  "requirementsRef": "\u00a74.2, \u00a74.3, \u00a74.4",
  "cases": [],
  "registry": {
    "schemaVersion": "1.0",
    "schemas": [
      {
        "name": "NormalizedSearchResult",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "snippet": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "enum": [
                "exa",
                "arxiv",
                "github",
                "huggingface"
              ]
            },
            "source_type": {
              "type": "string",
              "enum": [
                "web",
                "paper",
                "repo",
                "model"
              ]
            }
          },
          "required": [
            "title",
            "url",
            "source"
          ]
        }
      },
      {
        "name": "NormalizedSearchResponse",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "$ref": "#/schemas/NormalizedSearchResult"
              }
            }
          }
        }
      }
    ],
    "servers": [
      {
        "name": "search-service",
        "version": "1.0.0",
        "description": "External search APIs (Exa, arXiv, GitHub, HuggingFace)",
        "url": "http://localhost:8001/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "exa_search"
          },
          {
            "version": "1.0.0",
            "name": "arxiv_search"
          },
          {
            "version": "1.0.0",
            "name": "github_search"
          },
          {
            "version": "1.0.0",
            "name": "huggingface_search"
          }
        ]
      },
      {
        "name": "fetch-service",
        "version": "1.0.0",
        "description": "URL content fetching and extraction",
        "url": "http://localhost:8002/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "url_fetch"
          },
          {
            "version": "1.0.0",
            "name": "extract_urls"
          },
          {
            "version": "1.0.0",
            "name": "batch_fetch"
          }
        ]
      },
      {
        "name": "entity-service",
        "version": "1.0.0",
        "description": "Knowledge graph entities and relations with vector search",
        "url": "http://localhost:8003/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "entity_search"
          },
          {
            "version": "1.0.0",
            "name": "create_entity"
          },
          {
            "version": "1.0.0",
            "name": "create_relation"
          }
        ]
      },
      {
        "name": "category-service",
        "version": "1.0.0",
        "description": "Hierarchical category taxonomy",
        "url": "http://localhost:8004/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "search_categories"
          },
          {
            "version": "1.0.0",
            "name": "create_category"
          }
        ]
      },
      {
        "name": "tag-service",
        "version": "1.0.0",
        "description": "Content tagging and organization",
        "url": "http://localhost:8005/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "register_content"
          },
          {
            "version": "1.0.0",
            "name": "tag_content"
          }
        ]
      }
    ],
    "tools": [
      {
        "name": "exa_search",
        "version": "1.0.0",
        "description": "Search the web using Exa API. Returns results with title, URL, text snippets, and scores.",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "exa_search"
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query for web search"
            },
            "num_results": {
              "type": "integer",
              "description": "Number of results to return (1-20)",
              "default": 10
            },
            "use_autoprompt": {
              "type": "boolean",
              "description": "Use Exa's autoprompt feature",
              "default": true
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "text": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "highlight": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "score": {
                    "type": "number"
                  },
                  "published_date": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "error": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      },
      {
        "name": "arxiv_search",
        "version": "1.0.0",
        "description": "Search arXiv for academic papers. Returns paper metadata including title, authors, abstract, and PDF URL. No API key required.",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "arxiv_search"
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query for arXiv papers"
            },
            "num_results": {
              "type": "integer",
              "description": "Number of papers to return (1-50)",
              "default": 10
            },
            "sort_by": {
              "type": "string",
              "description": "Sort order: relevance, lastUpdatedDate, submittedDate",
              "default": "relevance"
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "papers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "arxiv_id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "abstract": {
                    "type": "string"
                  },
                  "authors": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "categories": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "pdf_url": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "abs_url": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "published": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "error": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      },
      {
        "name": "github_search",
        "version": "1.0.0",
        "description": "Search GitHub for repositories or code. GITHUB_TOKEN optional but recommended to avoid rate limits.",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "github_search"
          }
