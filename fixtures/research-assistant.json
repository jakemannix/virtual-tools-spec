        "inputSchema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "Text to extract URLs from"
            },
            "domain_filter": {
              "type": [
                "string",
                "null"
              ],
              "description": "Only return URLs from this domain"
            }
          },
          "required": [
            "text"
          ]
        }
      },
      {
        "name": "register_content",
