                    "type": "string"
                  },
                  "description": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "stargazers_count": {
                    "type": "integer"
                  },
                  "forks_count": {
                    "type": "integer"
                  },
                  "language": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "topics": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "error": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      },
      {
        "name": "huggingface_search",
