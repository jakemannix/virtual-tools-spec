{
  "name": "research-assistant",
  "title": "Research Assistant \u2014 Multi-Source Search with Knowledge Graph",
  "description": "A research gateway that composes 5 microservices into powerful virtual tools. Demonstrates output transforms (normalize heterogeneous APIs), scatter-gather (parallel multi-source search), pipelines (search \u2192 fetch \u2192 merge), and cross-service data flow. Base MCP tools and virtual tools are on equal footing in the registry.",
  "requirementsRef": "\u00a74.2, \u00a74.3, \u00a74.4",
  "cases": [],
  "registry": {
    "schemaVersion": "1.0",
    "schemas": [
      {
        "name": "NormalizedSearchResult",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "snippet": {
              "type": "string"
            },
            "source": {
              "type": "string",
              "enum": [
                "exa",
                "arxiv",
                "github",
                "huggingface"
              ]
            },
            "source_type": {
              "type": "string",
              "enum": [
                "web",
                "paper",
                "repo",
                "model"
              ]
            }
          },
          "required": [
            "title",
            "url",
            "source"
          ]
        }
      },
      {
        "name": "NormalizedSearchResponse",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "$ref": "#/schemas/NormalizedSearchResult"
              }
            }
          }
        }
      },
      {
        "name": "ExaSearchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query for web search"
            },
            "num_results": {
              "type": "integer",
              "description": "Number of results to return (1-20)",
              "default": 10
            },
            "use_autoprompt": {
              "type": "boolean",
              "description": "Use Exa's autoprompt feature",
              "default": true
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "ExaSearchResponse",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "text": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "highlight": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "score": {
                    "type": "number"
                  },
                  "published_date": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "error": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      },
      {
        "name": "ArxivSearchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query for arXiv papers"
            },
            "num_results": {
              "type": "integer",
              "description": "Number of papers to return (1-50)",
              "default": 10
            },
            "sort_by": {
              "type": "string",
              "description": "Sort order: relevance, lastUpdatedDate, submittedDate",
              "default": "relevance"
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "ArxivSearchResponse",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "papers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "arxiv_id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "abstract": {
                    "type": "string"
                  },
                  "authors": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "categories": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "pdf_url": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "abs_url": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "published": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "error": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      },
      {
        "name": "GitHubSearchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query for GitHub repositories"
            },
            "num_results": {
              "type": "integer",
              "description": "Number of repositories to return (1-30)",
              "default": 10
            },
            "search_type": {
              "type": "string",
              "description": "What to search: repositories, code",
              "default": "repositories"
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "GitHubSearchResponse",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "search_type": {
              "type": "string"
            },
            "total_count": {
              "type": "integer"
            },
            "repos": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "full_name": {
                    "type": "string"
                  },
                  "html_url": {
                    "type": "string"
                  },
                  "description": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "stargazers_count": {
                    "type": "integer"
                  },
                  "forks_count": {
                    "type": "integer"
                  },
                  "language": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "topics": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "error": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      },
      {
        "name": "HuggingFaceSearchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query for HuggingFace"
            },
            "num_results": {
              "type": "integer",
              "description": "Number of results to return (1-30)",
              "default": 10
            },
            "search_type": {
              "type": "string",
              "description": "What to search: models, datasets, spaces",
              "default": "models"
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "HuggingFaceSearchResponse",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "search_type": {
              "type": "string"
            },
            "models": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "description": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "downloads": {
                    "type": "integer"
                  },
                  "pipeline_tag": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "error": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      },
      {
        "name": "EntitySearchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Semantic search query"
            },
            "limit": {
              "type": "integer",
              "description": "Max results",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "CreateEntityInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Entity name"
            },
            "entity_type": {
              "type": "string",
              "description": "Type: paper, concept, tool, person, organization"
            },
            "description": {
              "type": "string",
              "description": "Detailed description"
            },
            "properties": {
              "type": "object",
              "description": "Additional properties (url, authors, etc.)"
            }
          },
          "required": [
            "name",
            "entity_type",
            "description"
          ]
        }
      },
      {
        "name": "CreateRelationInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "subject_id": {
              "type": "string",
              "description": "Source entity ID"
            },
            "object_id": {
              "type": "string",
              "description": "Target entity ID"
            },
            "predicate": {
              "type": "string",
              "description": "Relationship: extends, cites, implements, related_to, authored_by"
            }
          },
          "required": [
            "subject_id",
            "object_id",
            "predicate"
          ]
        }
      },
      {
        "name": "SearchCategoriesInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            },
            "limit": {
              "type": "integer",
              "description": "Max results",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "CreateCategoryInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Category name"
            },
            "description": {
              "type": "string",
              "description": "What belongs in this category"
            },
            "parent_id": {
              "type": [
                "string",
                "null"
              ],
              "description": "Parent category ID (null for root)"
            }
          },
          "required": [
            "name",
            "description"
          ]
        }
      },
      {
        "name": "BatchFetchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "urls": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "URLs to fetch"
            },
            "max_length_per_url": {
              "type": "integer",
              "description": "Max content length per URL",
              "default": 5000
            }
          },
          "required": [
            "urls"
          ]
        }
      },
      {
        "name": "UrlFetchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "URL to fetch"
            },
            "max_length": {
              "type": "integer",
              "description": "Max content length",
              "default": 10000
            }
          },
          "required": [
            "url"
          ]
        }
      },
      {
        "name": "ExtractUrlsInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "Text to extract URLs from"
            },
            "domain_filter": {
              "type": [
                "string",
                "null"
              ],
              "description": "Only return URLs from this domain"
            }
          },
          "required": [
            "text"
          ]
        }
      },
      {
        "name": "RegisterContentInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "Content URL"
            },
            "summary": {
              "type": "string",
              "description": "Content summary"
            },
            "metadata": {
              "type": "object",
              "description": "Additional metadata"
            }
          },
          "required": [
            "url"
          ]
        }
      },
      {
        "name": "TagContentInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "content_id": {
              "type": "string",
              "description": "Content ID (from register_content)"
            },
            "category_id": {
              "type": "string",
              "description": "Category ID to tag with"
            }
          },
          "required": [
            "content_id",
            "category_id"
          ]
        }
      },
      {
        "name": "SearchInput",
        "version": "1.0.0",
        "description": "Shared input schema for all search tools — virtual and composed",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            },
            "num_results": {
              "type": "integer",
              "description": "Maximum number of results to return",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "MultiSourceSearchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            },
            "num_results": {
              "type": "integer",
              "description": "Max results per source",
              "default": 5
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "FetchAndExtractInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "URL to fetch and extract links from"
            }
          },
          "required": [
            "url"
          ]
        }
      },
      {
        "name": "ResearchAndFetchInput",
        "version": "1.0.0",
        "schema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Research topic"
            },
            "num_results": {
              "type": "integer",
              "description": "Max results per source",
              "default": 5
            },
            "limit": {
              "type": "integer",
              "description": "Max entities/categories",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "StoreResearchFindingInput",
        "version": "1.0.0",
        "description": "Agent-facing schema for saving research findings. Uses domain language: 'title' (maps to backend 'name'), 'summary' (maps to 'description'), 'kind' (maps to 'entity_type', defaults to 'paper'). Backend 'properties' field is projected away.",
        "schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Title of the research finding"
            },
            "kind": {
              "type": "string",
              "description": "What kind of finding (defaults to 'paper')",
              "enum": [
                "paper",
                "concept",
                "tool",
                "person",
                "organization",
                "dataset",
                "model"
              ],
              "default": "paper"
            },
            "summary": {
              "type": "string",
              "description": "Summary of the finding"
            },
            "url": {
              "type": "string",
              "description": "URL of the source"
            },
            "category_id": {
              "type": "string",
              "description": "Category to tag this finding under"
            }
          },
          "required": [
            "title",
            "summary",
            "url",
            "category_id"
          ]
        }
      }
    ],
    "servers": [
      {
        "name": "search-service",
        "version": "1.0.0",
        "description": "External search APIs (Exa, arXiv, GitHub, HuggingFace)",
        "url": "http://localhost:8001/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "exa_search"
          },
          {
            "version": "1.0.0",
            "name": "arxiv_search"
          },
          {
            "version": "1.0.0",
            "name": "github_search"
          },
          {
            "version": "1.0.0",
            "name": "huggingface_search"
          }
        ]
      },
      {
        "name": "fetch-service",
        "version": "1.0.0",
        "description": "URL content fetching and extraction",
        "url": "http://localhost:8002/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "url_fetch"
          },
          {
            "version": "1.0.0",
            "name": "extract_urls"
          },
          {
            "version": "1.0.0",
            "name": "batch_fetch"
          }
        ]
      },
      {
        "name": "entity-service",
        "version": "1.0.0",
        "description": "Knowledge graph entities and relations with vector search",
        "url": "http://localhost:8003/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "entity_search"
          },
          {
            "version": "1.0.0",
            "name": "create_entity"
          },
          {
            "version": "1.0.0",
            "name": "create_relation"
          }
        ]
      },
      {
        "name": "category-service",
        "version": "1.0.0",
        "description": "Hierarchical category taxonomy",
        "url": "http://localhost:8004/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "search_categories"
          },
          {
            "version": "1.0.0",
            "name": "create_category"
          }
        ]
      },
      {
        "name": "tag-service",
        "version": "1.0.0",
        "description": "Content tagging and organization",
        "url": "http://localhost:8005/mcp",
        "providedTools": [
          {
            "version": "1.0.0",
            "name": "register_content"
          },
          {
            "version": "1.0.0",
            "name": "tag_content"
          }
        ]
      }
    ],
    "tools": [
      {
        "name": "exa_search",
        "version": "1.0.0",
        "description": "Search the web. Returns results with title, URL, text snippets, and relevance scores.",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "exa_search"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/ExaSearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/ExaSearchResponse"
        }
      },
      {
        "name": "arxiv_search",
        "version": "1.0.0",
        "description": "Search academic preprint papers. Returns title, authors, abstract, and PDF link.",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "arxiv_search"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/ArxivSearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/ArxivSearchResponse"
        }
      },
      {
        "name": "github_search",
        "version": "1.0.0",
        "description": "Search code repositories. Returns repo name, URL, description, stars, and language.",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "github_search"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/GitHubSearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/GitHubSearchResponse"
        }
      },
      {
        "name": "huggingface_search",
        "version": "1.0.0",
        "description": "Search ML model repositories. Returns model ID, description, download count, and tags.",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "huggingface_search"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/HuggingFaceSearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/HuggingFaceSearchResponse"
        }
      },
      {
        "name": "entity_search",
        "version": "1.0.0",
        "description": "Search your knowledge graph for previously saved entities by semantic similarity",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "entity-service",
            "tool": "entity_search"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/EntitySearchInput"
        }
      },
      {
        "name": "create_entity",
        "version": "1.0.0",
        "description": "Save an entity to the knowledge graph with a name, type, and description for future retrieval",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "entity-service",
            "tool": "create_entity"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/CreateEntityInput"
        }
      },
      {
        "name": "create_relation",
        "version": "1.0.0",
        "description": "Create a relationship between two entities (e.g. 'paper X cites paper Y', 'tool A implements concept B')",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "entity-service",
            "tool": "create_relation"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/CreateRelationInput"
        }
      },
      {
        "name": "search_categories",
        "version": "1.0.0",
        "description": "Find categories in your taxonomy that match a topic",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "category-service",
            "tool": "search_categories"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/SearchCategoriesInput"
        }
      },
      {
        "name": "create_category",
        "version": "1.0.0",
        "description": "Create a new category for organizing research findings. Set parent_id to nest under an existing category.",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "category-service",
            "tool": "create_category"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/CreateCategoryInput"
        }
      },
      {
        "name": "batch_fetch",
        "version": "1.0.0",
        "description": "Fetch and extract text content from multiple URLs in parallel",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "fetch-service",
            "tool": "batch_fetch"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/BatchFetchInput"
        }
      },
      {
        "name": "url_fetch",
        "version": "1.0.0",
        "description": "Fetch a URL and extract its text content, title, and metadata",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "fetch-service",
            "tool": "url_fetch"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/UrlFetchInput"
        }
      },
      {
        "name": "extract_urls",
        "version": "1.0.0",
        "description": "Extract all URLs from a block of text, optionally filtering to a specific domain",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "fetch-service",
            "tool": "extract_urls"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/ExtractUrlsInput"
        }
      },
      {
        "name": "register_content",
        "version": "1.0.0",
        "description": "Register a piece of content (by URL and summary) so it can be tagged with categories",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "tag-service",
            "tool": "register_content"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/RegisterContentInput"
        }
      },
      {
        "name": "tag_content",
        "version": "1.0.0",
        "description": "Tag a registered piece of content with a category for organized retrieval",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "tag-service",
            "tool": "tag_content"
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/TagContentInput"
        }
      },
      {
        "name": "web_search",
        "version": "1.0.0",
        "description": "Search the web for pages, articles, and documentation relevant to your research topic",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "exa_search"
          }
        },
        "outputTransform": {
          "mappings": {
            "results": {
              "over": "$.results",
              "fields": {
                "title": {
                  "path": "$.title",
                  "default": ""
                },
                "url": {
                  "path": "$.url",
                  "default": ""
                },
                "snippet": {
                  "path": "$.text",
                  "default": ""
                },
                "source": {
                  "value": "exa"
                },
                "source_type": {
                  "value": "web"
                }
              }
            }
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/SearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/NormalizedSearchResponse"
        }
      },
      {
        "name": "paper_search",
        "version": "1.0.0",
        "description": "Search academic papers on arXiv for research publications, preprints, and technical papers",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "arxiv_search"
          }
        },
        "outputTransform": {
          "mappings": {
            "results": {
              "over": "$.papers",
              "fields": {
                "title": {
                  "path": "$.title",
                  "default": ""
                },
                "url": {
                  "path": "$.pdf_url",
                  "default": ""
                },
                "snippet": {
                  "path": "$.abstract",
                  "default": ""
                },
                "source": {
                  "value": "arxiv"
                },
                "source_type": {
                  "value": "paper"
                }
              }
            }
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/SearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/NormalizedSearchResponse"
        }
      },
      {
        "name": "code_search",
        "version": "1.0.0",
        "description": "Search GitHub repositories for open-source code, libraries, and projects",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "github_search"
          }
        },
        "outputTransform": {
          "mappings": {
            "results": {
              "over": "$.repos",
              "fields": {
                "title": {
                  "path": "$.full_name",
                  "default": ""
                },
                "url": {
                  "path": "$.html_url",
                  "default": ""
                },
                "snippet": {
                  "path": "$.description",
                  "default": ""
                },
                "source": {
                  "value": "github"
                },
                "source_type": {
                  "value": "repo"
                }
              }
            }
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/SearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/NormalizedSearchResponse"
        }
      },
      {
        "name": "model_search",
        "version": "1.0.0",
        "description": "Search HuggingFace for ML models, datasets, and spaces",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "huggingface_search"
          }
        },
        "outputTransform": {
          "mappings": {
            "results": {
              "over": "$.models",
              "fields": {
                "title": {
                  "path": "$.id",
                  "default": ""
                },
                "url": {
                  "path": "$.url",
                  "default": ""
                },
                "snippet": {
                  "path": "$.description",
                  "default": ""
                },
                "source": {
                  "value": "huggingface"
                },
                "source_type": {
                  "value": "model"
                }
              }
            }
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/SearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/NormalizedSearchResponse"
        }
      },
      {
        "name": "multi_source_search",
        "version": "1.0.0",
        "description": "Searches for models, papers, source code, and the wider web in parallel, deduplicates results by URL",
        "environment": "prod",
        "implementation": {
          "composition": {
            "scatterGather": {
              "targets": [
                {
                  "tool": "web_search",
                  "version": "1.0.0"
                },
                {
                  "tool": "paper_search",
                  "version": "1.0.0"
                },
                {
                  "tool": "code_search",
                  "version": "1.0.0"
                },
                {
                  "tool": "model_search",
                  "version": "1.0.0"
                }
              ],
              "aggregation": [
                {
                  "extract": {
                    "path": "$.results"
                  }
                },
                {
                  "flatten": true
                },
                {
                  "dedupe": {
                    "field": "$.url"
                  }
                },
                {
                  "wrap": {
                    "field": "results"
                  }
                }
              ],
              "timeoutMs": 30000
            }
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/MultiSourceSearchInput"
        },
        "outputSchema": {
          "$ref": "#/schemas/NormalizedSearchResponse"
        }
      },
      {
        "name": "fetch_and_extract",
        "version": "1.0.0",
        "description": "Fetch a URL and extract all links found in its content",
        "environment": "prod",
        "implementation": {
          "composition": {
            "pipeline": {
              "steps": [
                {
                  "id": "fetch",
                  "operation": {
                    "tool": "url_fetch",
                    "version": "1.0.0"
                  }
                },
                {
                  "id": "extract",
                  "operation": {
                    "tool": "extract_urls",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "text": {
                          "fromStep": {
                            "stepId": "fetch",
                            "path": "$.content"
                          }
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/FetchAndExtractInput"
        }
      },
      {
        "name": "research_and_fetch",
        "version": "1.0.0",
        "description": "Research a topic end-to-end: searches your knowledge graph and multiple external sources in parallel, then fetches the full content of top results. Use this as your primary research tool.",
        "environment": "prod",
        "implementation": {
          "composition": {
            "pipeline": {
              "steps": [
                {
                  "id": "context",
                  "operation": {
                    "composition": {
                      "scatterGather": {
                        "targets": [
                          {
                            "tool": "entity_search",
                            "version": "1.0.0"
                          },
                          {
                            "tool": "search_categories",
                            "version": "1.0.0"
                          },
                          {
                            "tool": "multi_source_search",
                            "version": "1.0.0"
                          }
                        ],
                        "aggregation": [
                          {
                            "merge": true
                          }
                        ],
                        "timeoutMs": 30000
                      }
                    }
                  },
                  "input": {
                    "fromInput": {
                      "path": "$"
                    }
                  }
                },
                {
                  "id": "fetch",
                  "operation": {
                    "tool": "batch_fetch",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "urls": {
                          "fromStep": {
                            "stepId": "context",
                            "path": "$.results[*].url"
                          }
                        },
                        "max_length_per_url": {
                          "constant": 3000
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/ResearchAndFetchInput"
        }
      },
      {
        "name": "store_research_finding",
        "version": "1.0.0",
        "description": "Save a research finding: creates a knowledge graph entity, registers the content, and tags it under a category. Provide a title, summary, URL, and category. Kind defaults to 'paper' if not specified.",
        "environment": "prod",
        "implementation": {
          "composition": {
            "pipeline": {
              "steps": [
                {
                  "id": "create_entity",
                  "operation": {
                    "tool": "create_entity",
                    "version": "1.0.0"
                  },
                  "fieldMapping": {
                    "title": "name",
                    "summary": "description",
                    "kind": "entity_type"
                  },
                  "defaults": {
                    "kind": "paper"
                  },
                  "projection": ["properties"],
                  "input": {
                    "construct": {
                      "fields": {
                        "name": {
                          "fromInput": {
                            "path": "$.title"
                          }
                        },
                        "entity_type": {
                          "fromInput": {
                            "path": "$.kind"
                          }
                        },
                        "description": {
                          "fromInput": {
                            "path": "$.summary"
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "id": "register",
                  "operation": {
                    "tool": "register_content",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "url": {
                          "fromInput": {
                            "path": "$.url"
                          }
                        },
                        "summary": {
                          "fromInput": {
                            "path": "$.description"
                          }
                        },
                        "metadata": {
                          "construct": {
                            "fields": {
                              "entity_id": {
                                "fromStep": {
                                  "stepId": "create_entity",
                                  "path": "$.entity.id"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "id": "tag",
                  "operation": {
                    "tool": "tag_content",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "content_id": {
                          "fromStep": {
                            "stepId": "register",
                            "path": "$.content.id"
                          }
                        },
                        "category_id": {
                          "fromInput": {
                            "path": "$.category_id"
                          }
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        },
        "inputSchema": {
          "$ref": "#/schemas/StoreResearchFindingInput"
        }
      }
    ],
    "agents": [
      {
        "agentCard": {
          "name": "research-agent",
          "version": "1.0.0",
          "url": "http://localhost:9001",
          "description": "Research assistant that orchestrates multi-source search, content fetching, and knowledge graph management via virtual tools"
        },
        "environment": "prod",
        "dependencies": [
          {
            "tool": "research_and_fetch",
            "versionRange": "1.*"
          },
          {
            "tool": "multi_source_search",
            "versionRange": "1.*"
          },
          {
            "tool": "store_research_finding",
            "versionRange": "1.*"
          },
          {
            "tool": "create_entity",
            "versionRange": "1.*"
          },
          {
            "tool": "create_category",
            "versionRange": "1.*"
          }
        ]
      }
    ]
  }
}
