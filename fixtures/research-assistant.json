              "type": "integer",
              "description": "Number of results (1-30)",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": {
          "$ref": "#/schemas/NormalizedSearchResponse"
        }
      },
      {
        "name": "multi_source_search",
        "version": "1.0.0",
        "description": "Searches Exa, arXiv, GitHub, and HuggingFace in parallel via normalized wrappers, deduplicates by URL",
        "environment": "prod",
        "implementation": {
          "composition": {
            "scatterGather": {
              "targets": [
                {
                  "tool": "normalized_exa",
                  "version": "1.0.0"
                },
                {
                  "tool": "normalized_arxiv",
                  "version": "1.0.0"
                },
                {
                  "tool": "normalized_github",
                  "version": "1.0.0"
                },
                {
                  "tool": "normalized_huggingface",
                  "version": "1.0.0"
                }
              ],
              "aggregation": [
                {
                  "extract": {
                    "path": "$.results"
                  }
                },
                {
                  "flatten": true
                },
                {
                  "dedupe": {
                    "field": "$.url"
                  }
                },
                {
                  "wrap": {
                    "field": "results"
                  }
                }
              ],
              "timeoutMs": 30000
            }
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            },
            "num_results": {
              "type": "integer",
              "description": "Max results per source",
              "default": 5
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": {
          "$ref": "#/schemas/NormalizedSearchResponse"
        }
      },
      {
        "name": "fetch_and_extract",
        "version": "1.0.0",
        "description": "Fetches a URL then extracts links from the content \u2014 two-step pipeline across fetch-service tools",
        "environment": "prod",
        "implementation": {
          "composition": {
            "pipeline": {
              "steps": [
                {
                  "id": "fetch",
                  "operation": {
                    "tool": "url_fetch",
                    "version": "1.0.0"
                  }
                },
                {
                  "id": "extract",
                  "operation": {
                    "tool": "extract_urls",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "text": {
                          "fromStep": {
                            "stepId": "fetch",
                            "path": "$.content"
                          }
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "URL to fetch and extract links from"
            }
          },
          "required": [
            "url"
          ]
        }
      },
      {
        "name": "research_and_fetch",
        "version": "1.0.0",
        "description": "Complete research workflow: searches knowledge graph + 4 external sources in parallel, then fetches page content from top results",
        "environment": "prod",
        "implementation": {
          "composition": {
            "pipeline": {
              "steps": [
                {
                  "id": "context",
                  "operation": {
                    "composition": {
                      "scatterGather": {
                        "targets": [
                          {
                            "tool": "entity_search",
                            "version": "1.0.0"
                          },
                          {
                            "tool": "search_categories",
                            "version": "1.0.0"
                          },
                          {
                            "tool": "multi_source_search",
                            "version": "1.0.0"
                          }
                        ],
                        "aggregation": [
                          {
                            "merge": true
                          }
                        ],
                        "timeoutMs": 30000
                      }
                    }
                  },
                  "input": {
                    "fromInput": {
                      "path": "$"
                    }
                  }
                },
                {
                  "id": "fetch",
                  "operation": {
                    "tool": "batch_fetch",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "urls": {
                          "fromStep": {
                            "stepId": "context",
                            "path": "$.results[*].url"
                          }
                        },
                        "max_length_per_url": {
                          "constant": 3000
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Research topic"
            },
            "num_results": {
              "type": "integer",
              "description": "Max results per source",
              "default": 5
            },
            "limit": {
              "type": "integer",
              "description": "Max entities/categories",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "store_research_finding",
        "version": "1.0.0",
        "description": "Cross-service pipeline: creates entity \u2192 registers content \u2192 tags it. Links data across entity-service and tag-service boundaries.",
        "environment": "prod",
        "implementation": {
          "composition": {
            "pipeline": {
              "steps": [
                {
                  "id": "create_entity",
                  "operation": {
                    "tool": "create_entity",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "name": {
                          "fromInput": {
                            "path": "$.title"
                          }
                        },
                        "entity_type": {
                          "fromInput": {
                            "path": "$.entity_type"
                          }
                        },
                        "description": {
                          "fromInput": {
                            "path": "$.description"
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "id": "register",
                  "operation": {
                    "tool": "register_content",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "url": {
                          "fromInput": {
                            "path": "$.url"
                          }
                        },
                        "summary": {
                          "fromInput": {
                            "path": "$.description"
                          }
                        },
                        "metadata": {
                          "construct": {
                            "fields": {
                              "entity_id": {
                                "fromStep": {
                                  "stepId": "create_entity",
                                  "path": "$.entity.id"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "id": "tag",
                  "operation": {
                    "tool": "tag_content",
                    "version": "1.0.0"
                  },
                  "input": {
                    "construct": {
                      "fields": {
                        "content_id": {
                          "fromStep": {
                            "stepId": "register",
                            "path": "$.content.id"
                          }
                        },
                        "category_id": {
                          "fromInput": {
                            "path": "$.category_id"
                          }
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "entity_type": {
              "type": "string",
              "enum": [
                "paper",
                "concept",
                "tool",
                "person",
                "organization",
                "dataset",
                "model"
              ]
            },
            "description": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "category_id": {
              "type": "string"
            }
          },
          "required": [
            "title",
            "entity_type",
            "description",
            "url",
            "category_id"
          ]
        }
      }
    ],
    "agents": [
      {
        "agentCard": {
          "name": "research-agent",
          "version": "1.0.0",
          "url": "http://localhost:9001",
          "description": "Research assistant that orchestrates multi-source search, content fetching, and knowledge graph management via virtual tools"
        },
        "environment": "prod",
        "dependencies": [
          {
            "tool": "research_and_fetch",
            "versionRange": "1.*"
          },
          {
            "tool": "multi_source_search",
            "versionRange": "1.*"
          },
          {
            "tool": "store_research_finding",
            "versionRange": "1.*"
          },
          {
            "tool": "create_entity",
            "versionRange": "1.*"
          },
          {
            "tool": "create_category",
            "versionRange": "1.*"
          }
        ]
      }
    ]
  }
}
