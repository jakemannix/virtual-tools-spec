            },
            "description": {
              "type": "string",
              "description": "What belongs in this category"
            },
            "parent_id": {
              "type": [
                "string",
                "null"
              ],
              "description": "Parent category ID (null for root)"
            }
          },
          "required": [
            "name",
            "description"
          ]
        }
      },
      {
        "name": "batch_fetch",
        "version": "1.0.0",
        "description": "Fetch content from multiple URLs in parallel",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "fetch-service",
            "tool": "batch_fetch"
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "urls": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "URLs to fetch"
            },
            "max_length_per_url": {
              "type": "integer",
              "description": "Max content length per URL",
              "default": 5000
            }
          },
          "required": [
            "urls"
          ]
        }
      },
      {
        "name": "url_fetch",
        "version": "1.0.0",
        "description": "Fetch a single URL and extract text content and metadata",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "fetch-service",
            "tool": "url_fetch"
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "URL to fetch"
            },
            "max_length": {
              "type": "integer",
              "description": "Max content length",
              "default": 10000
            }
          },
          "required": [
            "url"
          ]
        }
      },
      {
        "name": "extract_urls",
