      {
        "name": "normalized_exa",
        "version": "1.0.0",
        "description": "Exa web search with normalized output \u2014 maps native Exa response to common NormalizedSearchResponse schema",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "search-service",
            "tool": "exa_search"
          }
        },
        "outputTransform": {
          "mappings": {
            "results": {
              "over": "$.results",
              "fields": {
                "title": {
                  "path": "$.title",
                  "default": ""
                },
                "url": {
                  "path": "$.url",
                  "default": ""
                },
                "snippet": {
                  "path": "$.text",
                  "default": ""
                },
                "source": {
                  "value": "exa"
                },
                "source_type": {
                  "value": "web"
                }
              }
            }
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query"
            },
            "num_results": {
              "type": "integer",
              "description": "Number of results (1-20)",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": {
          "$ref": "#/schemas/NormalizedSearchResponse"
        }
      },
