                "null"
              ]
            }
          }
        }
      },
      {
        "name": "entity_search",
        "version": "1.0.0",
        "description": "Semantic search over knowledge graph entity descriptions using vector similarity",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "entity-service",
            "tool": "entity_search"
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Semantic search query"
            },
            "limit": {
              "type": "integer",
              "description": "Max results",
              "default": 10
            }
          },
          "required": [
            "query"
          ]
        }
      },
      {
        "name": "create_entity",
        "version": "1.0.0",
        "description": "Add an entity to the knowledge graph (paper, concept, tool, person, etc.)",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "entity-service",
            "tool": "create_entity"
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Entity name"
            },
            "entity_type": {
              "type": "string",
              "description": "Type: paper, concept, tool, person, organization"
            },
            "description": {
              "type": "string",
              "description": "Detailed description"
            },
            "properties": {
              "type": "object",
              "description": "Additional properties (url, authors, etc.)"
            }
          },
          "required": [
            "name",
            "entity_type",
            "description"
          ]
        }
      },
      {
        "name": "create_relation",
        "version": "1.0.0",
        "description": "Link two entities in the knowledge graph with a predicate",
        "environment": "prod",
        "implementation": {
          "source": {
            "server": "entity-service",
            "tool": "create_relation"
          }
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "subject_id": {
              "type": "string",
              "description": "Source entity ID"
            },
            "object_id": {
              "type": "string",
              "description": "Target entity ID"
            },
            "predicate": {
              "type": "string",
              "description": "Relationship: extends, cites, implements, related_to, authored_by"
            }
          },
          "required": [
            "subject_id",
            "object_id",
            "predicate"
          ]
        }
      },
