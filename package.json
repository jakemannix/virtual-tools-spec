{
  "name": "@virtual-tools/spec",
  "version": "0.1.0",
  "description": "Virtual Tools Specification — canonical type definitions and validation",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jakemannix/virtual-tools-spec.git"
  },
  "type": "module",
  "main": "dist/schema.js",
  "types": "dist/schema.d.ts",
  "exports": {
    ".": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    },
    "./api": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./validate": {
      "import": "./dist/validate.js",
      "types": "./dist/validate.d.ts"
    },
    "./registry": {
      "import": "./dist/registry.js",
      "types": "./dist/registry.d.ts"
    },
    "./dsl": {
      "import": "./dist/dsl.js",
      "types": "./dist/dsl.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "generate:json-schema": "tsx src/generate-schema.ts > schema.json",
    "generate:openapi": "tsx src/generate-openapi.ts > openapi.yaml",
    "generate": "npm run generate:json-schema && npm run generate:openapi",
    "test": "vitest run",
    "test:watch": "vitest",
    "editor": "tsx editor/server.ts",
    "editor:demo": "tsx editor/server.ts --fixture fixtures/b5-lineage.json"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "semver": "^7.7.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.8.3",
    "zod-to-json-schema": "^3.24.0"
  }
}
